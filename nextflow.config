params {
    input        = null
    fasta        = null
    gff          = null
    outdir       = 'results'
    strandedness = 'unstranded'   // unstranded | forward | reverse
    max_cpus     = 16

    // featureCounts
    fc_feature_type  = 'CDS'
    fc_group_by      = 'locus_tag'
    fc_extra_args    = '-M --fraction'   // count multi-mappers as fractions

    // bowtie2
    bt2_extra_args   = '--sensitive --no-discordant -k 200'
}

process {
    withName: 'PREPARE_GFF' {
        container = 'https://depot.galaxyproject.org/singularity/python:3.9--1'
        cpus      = 1
        memory    = '2 GB'
        time      = '30m'
    }
    withName: 'BOWTIE2_BUILD' {
        container = 'https://depot.galaxyproject.org/singularity/bowtie2:2.5.4--py39h6fed5c7_0'
        cpus      = { Math.min(params.max_cpus as int, 8) }
        memory    = '16 GB'
        time      = '2h'
    }
    withName: 'BOWTIE2_ALIGN' {
        container = 'https://depot.galaxyproject.org/singularity/mulled-v2-ac74a7f02cebcfbc0119723e2041d4a4b9c8e5df:63ead8b3fba659400ae9ca794c0459d1b536e95e-0'
        cpus      = { params.max_cpus as int }
        memory    = '32 GB'
        time      = '12h'
    }
    withName: 'SAMTOOLS_SORT' {
        container = 'https://depot.galaxyproject.org/singularity/samtools:1.19.2--h50ea8bc_1'
        cpus      = { Math.min(params.max_cpus as int, 8) }
        memory    = '16 GB'
        time      = '2h'
    }
    withName: 'SAMTOOLS_INDEX' {
        container = 'https://depot.galaxyproject.org/singularity/samtools:1.19.2--h50ea8bc_1'
        cpus      = { Math.min(params.max_cpus as int, 4) }
        memory    = '8 GB'
        time      = '1h'
    }
    withName: 'FEATURECOUNTS' {
        container = 'https://depot.galaxyproject.org/singularity/subread:2.0.6--he4a0461_2'
        cpus      = { Math.min(params.max_cpus as int, 16) }
        memory    = '32 GB'
        time      = '4h'
    }
    withName: 'CALC_TPM' {
        container = 'https://depot.galaxyproject.org/singularity/python:3.9--1'
        cpus      = 2
        memory    = '4 GB'
        time      = '30m'
    }
}

profiles {
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        singularity.cacheDir   = System.getenv('NXF_SINGULARITY_CACHEDIR') ?: "${HOME}/.singularity"
    }
    conda {
        conda.enabled = true
    }
    slurm {
        process.executor      = 'slurm'
        process.queue         = 'batch'
        process.clusterOptions = '--account=asbhatt'
    }
    test {
        params.input = "${projectDir}/test/samplesheet.csv"
        params.fasta = "${projectDir}/test/genome.fna"
        params.gff   = "${projectDir}/test/genome.gff3"
        params.outdir = 'test_results'
    }
}
